generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  phone        String?
  passwordHash String
  roleId       Int
  isActive     Boolean  @default(false)
  approvalStatus UserApprovalStatus @default(PENDING)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role          Role           @relation(fields: [roleId], references: [id])
  leaveRequests LeaveRequest[]

  @@index([roleId])
  @@index([email])
}

model Role {
  id        Int      @id
  name      String   @unique
  createdAt DateTime @default(now())

  users User[]
}

model LeaveRequest {
  id          String      @id @default(uuid())
  userId      String
  leaveType   LeaveType
  startDate   DateTime
  endDate     DateTime
  description String?
  status      LeaveStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

enum LeaveType {
  ANNUAL
  SICK
  PERSONAL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}
